    try:
        query = text("SELECT LocationId, LocationName FROM Location WHERE is_active = 1 ORDER BY LocationName ASC")
        result = session.execute(query)
        options = [{"label": "All Locations", "value": None}]
        for row in result:
            options.append({"label": row.LocationName, "value": row.LocationId})
        return options
    except Exception as e:
