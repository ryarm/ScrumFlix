# --- DATA FETCHING ---
def get_location_options():
    session = get_session()
    try:
        query = text("SELECT LocationId, LocationName FROM Location WHERE is_active = 1 ORDER BY LocationName ASC")
        result = session.execute(query)
        options = [{"label": "All Locations", "value": None}]
        for row in result:
            options.append({"label": row.LocationName, "value": row.LocationId})
        return options
    except Exception as e:
        print(f"Error fetching locations: {e}")
        return [{"label": "All Locations", "value": None}]
    finally:
        session.close()

def fetch_ticket_data(location_id=None, start_date="2020-01-01", end_date="2026-12-31"):
    try:
        query_str = """
            SELECT 
                L.LocationName,
                DATE(S.StartTime) AS SaleDate,
                M.Title,
                COUNT(T.TicketId) AS TicketsSold,
                SUM(S.PricePerTicket) AS TotalRevenue
            FROM Ticket T
            JOIN Showtime S ON T.ShowtimeId = S.ShowtimeId
            JOIN TheaterScreen TS ON S.TheaterScreenId = TS.TheaterScreenId
            JOIN Location L ON TS.LocationId = L.LocationId
            JOIN Movies M ON S.MovieId = M.MovieId
            WHERE DATE(T.TimeOfSale) BETWEEN :start_date AND :end_date
        """
        params = {"start_date": start_date, "end_date": end_date}
        if location_id is not None:
            query_str += " AND L.LocationId = :loc_id"
            params["loc_id"] = location_id
        query_str += " GROUP BY L.LocationName, DATE(S.StartTime), M.Title ORDER BY SaleDate DESC"

        with engine.connect() as conn:
            df = pd.read_sql(text(query_str), conn, params=params)
        if not df.empty:
            df['SaleDate'] = pd.to_datetime(df['SaleDate'])
        return df
    except Exception as e:
        print(f"Error fetching ticket data: {e}")
        return pd.DataFrame()

