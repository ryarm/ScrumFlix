def get_todays_emp_sch(location_id=None):
    today = date.today()
    try:
        # Note: Added 'AS ShiftStart' to match your dataframe formatting logic
        query_str = """
            SELECT E.EmployeeId, E.FirstName, E.LastName, S.AssignmentName, SH.StartTime AS ShiftStart
            FROM ScheduleAssignments S
            LEFT JOIN Shifts SH ON S.ShiftId = SH.ShiftId
            LEFT JOIN Employees E ON S.EmployeeId = E.EmployeeId
            WHERE DATE(S.ShiftStart) = :today
        """
        params = {"today": today}
        if location_id:
            query_str += " AND S.LocationId = :loc_id"
            params["loc_id"] = location_id
        with engine.connect() as conn:
            df = pd.read_sql(text(query_str), conn, params=params)
        if not df.empty:
            df["ShiftStart"] = pd.to_datetime(df["ShiftStart"]).dt.strftime("%I:%M %p")
        return df
    except Exception as e:
        print(f"Employee fetch error: {e}")
        return pd.DataFrame()

