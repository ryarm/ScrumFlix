        return [{"label": "All Locations", "value": None}]
    finally:
        session.close()

def fetch_ticket_data(location_id=None, start_date="2020-01-01", end_date="2026-12-31"):
    try:
        query_str = """
            SELECT L.LocationName, DATE(S.StartTime) AS SaleDate, M.Title,
                   COUNT(T.TicketId) AS TicketsSold, SUM(S.PricePerTicket) AS TotalRevenue
            FROM Ticket T
            JOIN Showtime S ON T.ShowtimeId = S.ShowtimeId
            JOIN TheaterScreen TS ON S.TheaterScreenId = TS.TheaterScreenId
            JOIN Location L ON TS.LocationId = L.LocationId
            JOIN Movies M ON S.MovieId = M.MovieId
            WHERE DATE(T.TimeOfSale) BETWEEN :start_date AND :end_date
            GROUP BY L.LocationName, SaleDate, M.Title ORDER BY SaleDate DESC
        """
        params = {"start_date": start_date, "end_date": end_date}
        if location_id:
            query_str = query_str.replace("WHERE", "WHERE L.LocationId = :loc_id AND")
            params["loc_id"] = location_id
        with engine.connect() as conn:
            return pd.read_sql(text(query_str), conn, params=params)
    except Exception as e:
        return pd.DataFrame()

def fetch_todays_showtimes(location_id=None):
    today = date.today()
    try:
        query_str = """
            SELECT S.ShowtimeId, M.Title, S.TheaterScreenID, S.StartTime,
                   (S.Capacity - COUNT(T.TicketId)) AS TicketsRemaining
            FROM Showtime S 
            JOIN Movies M ON S.MovieId = M.MovieId
            JOIN TheaterScreen TS ON S.TheaterScreenId = TS.TheaterScreenId
            LEFT JOIN Ticket T ON S.ShowtimeId = T.ShowtimeId
            WHERE DATE(S.StartTime) = :today
        """
        params = {"today": today}
        if location_id:
            query_str += " AND TS.LocationId = :loc_id"
            params["loc_id"] = location_id
        query_str += " GROUP BY S.ShowtimeId, M.Title, S.TheaterScreenID, S.StartTime, S.Capacity"
        with engine.connect() as conn:
            df = pd.read_sql(text(query_str), conn, params=params)
        if not df.empty:
            df["StartTime"] = pd.to_datetime(df["StartTime"]).dt.strftime("%I:%M %p")
        return df
    except Exception as e:
        return pd.DataFrame()

