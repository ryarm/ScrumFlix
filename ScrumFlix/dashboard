@app.callback(Output("page-content", "children"), [Input("url", "pathname")])
def display_page(pathname):
    if pathname == "/":
        return html.Div([
            html.H1("Welcome to Scrumflix Daily Operations Dashboard"),
            html.P("This is a snapshot of today's critical operations.")
        ])
    elif pathname == "/operations":
        return render_operations_layout()
    return html.H1("404: Not Found", className="text-danger")

# --- DASHBOARD LOGIC CALLBACKS ---
@callback(
    Output("data-grid", "rowData"),
    Output("revenue-graph", "figure"),
    Input("location-selector", "value"),
    Input("date-picker", "start_date"),
    Input("date-picker", "end_date"),
)
def update_dashboard(selected_location, start, end):
    df = fetch_ticket_data(selected_location, start, end)
    if df.empty:
        return [], px.histogram(title="No Data Found for Selection")

    fig = px.bar(df, x="SaleDate", y="TotalRevenue", color="Title", 
                 title="Revenue by Movie Over Time", barmode="group")
    fig.update_xaxes(type='category') 
    return df.to_dict("records"), fig

@callback(
    Output("download-dataframe-csv", "data"),
    Input("btn-csv", "n_clicks"),
    State("data-grid", "rowData"),
    prevent_initial_call=True,
)
def export_csv(n_clicks, row_data):
    if n_clicks and row_data:
        df_to_export = pd.DataFrame(row_data)
        return dcc.send_data_frame(df_to_export.to_csv, "scrumflix_ticket_report.csv", index=False)

