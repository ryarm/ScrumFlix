<?xml version="1.0" encoding="utf-8"?>
<!--
  File: /ScrumFlix/web.config
  Description: IIS / somee.com deployment configuration for the ScrumFlix ASP.NET Core MVC
               application. Configures the ASP.NET Core Module (ANCM) to host the app in
               out-of-process mode, sets standard security and performance headers, enables
               static file serving, and suppresses default IIS error pages so ASP.NET Core
               can handle all responses including 404s.

  IMPORTANT — somee.com deployment notes:
    1. Upload the PUBLISHED output (dotnet publish -c Release) not the source.
    2. Set the connection string in the somee.com control panel (Environment Variables),
       NOT in appsettings.json, to keep credentials out of source control.
    3. The processPath below points to dotnet.exe — somee.com supplies the runtime.
    4. stdoutLogEnabled should remain false in production; flip to true only to diagnose
       startup failures, then turn it off again and delete the logs/ folder.
-->
<configuration>

	<location path="." inheritInChildApplications="false">
		<system.webServer>

			<!-- ── ASP.NET Core Module v2 (out-of-process hosting) ─────────────── -->
			<handlers>
				<add name="aspNetCore"
					 path="*"
					 verb="*"
					 modules="AspNetCoreModuleV2"
					 resourceType="Unspecified" />
			</handlers>

			<aspNetCore processPath="dotnet"
						arguments=".\ScrumFlix.dll"
						stdoutLogEnabled="false"
						stdoutLogFile=".\logs\stdout"
						hostingModel="inprocess">
				<environmentVariables>
					<!-- Tell ASP.NET Core this is a Production environment -->
					<environmentVariable name="ASPNETCORE_ENVIRONMENT" value="Production" />
					<!--
            DO NOT add ConnectionStrings here.
            Set them in the somee.com control panel under:
            Website Settings → Application Settings (Environment Variables)
            Key:   ConnectionStrings__DefaultConnection
            Value: Server=...;Port=...;Database=defaultdb;User=...;Password=...;SslMode=Required;
          -->
				</environmentVariables>
				<handlerSettings>
					<handlerSetting name="enableShadowCopy" value="true" />
					<handlerSetting name="shadowCopyDirectory" value="../Protected.scrumflixtheatres.somee.com/ShadowCopy" />
					<handlerSetting name="cleanShadowCopyDirectory" value="true" />
				</handlerSettings>
			</aspNetCore>

			<!-- ── Static files ──────────────────────────────────────────────────── -->
			<staticContent>
				<!-- Serve .woff2 fonts correctly -->
				<remove fileExtension=".woff"  />
				<remove fileExtension=".woff2" />
				<mimeMap fileExtension=".woff"  mimeType="font/woff"  />
				<mimeMap fileExtension=".woff2" mimeType="font/woff2" />
			</staticContent>

			<!-- ── Security headers ───────────────────────────────────────────────── -->
			<httpProtocol>
				<customHeaders>
					<!-- Prevent MIME-type sniffing -->
					<add name="X-Content-Type-Options"    value="nosniff" />
					<!-- Prevent clickjacking -->
					<add name="X-Frame-Options"           value="SAMEORIGIN" />
					<!-- Enable XSS filter in older browsers -->
					<add name="X-XSS-Protection"          value="1; mode=block" />
					<!-- Remove the "Powered-By" header -->
					<remove name="X-Powered-By" />
				</customHeaders>
			</httpProtocol>

			<!-- ── HTTP → HTTPS redirect ──────────────────────────────────────────── -->
			<rewrite>
				<rules>
					<rule name="HTTP to HTTPS" stopProcessing="true">
						<match url="(.*)" />
						<conditions>
							<add input="{HTTPS}" pattern="^OFF$" ignoreCase="true" />
						</conditions>
						<action type="Redirect"
								url="https://{HTTP_HOST}/{R:1}"
								redirectType="Permanent" />
					</rule>
				</rules>
			</rewrite>

			<!-- ── Suppress IIS default error pages ──────────────────────────────── -->
			<!-- Let ASP.NET Core handle all errors (404, 500, etc.) -->
			<httpErrors existingResponse="PassThrough" />

			<!-- ── Request limits (generous for ticket + concession posts) ────────── -->
			<security>
				<requestFiltering>
					<!-- 10 MB max request body -->
					<requestLimits maxAllowedContentLength="10485760" />
				</requestFiltering>
			</security>

		</system.webServer>
	</location>

</configuration>
