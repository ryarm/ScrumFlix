@*
 * File: /ScrumFlix/Views/Movies/MovieEdit.cshtml
 * Description: Form for editing an existing movie entry.
*@
@model Movie
@{
    ViewData["Title"] = "Edit Movie";
}

<div class="sf-page-header">
    <div class="container-xl">
        <h1 class="sf-page-title"><i class="bi bi-pencil-square me-2"></i>Edit Movie</h1>
    </div>
</div>

<section class="sf-section">
    <div class="container-xl">
        <div class="row justify-content-center">
            <div class="col-lg-6">
                <div class="sf-form-card">
                    <form asp-controller="Movies" asp-action="MovieEdit" method="post">
                        @Html.AntiForgeryToken()
                        <input asp-for="MovieId" type="hidden" />
                        <div asp-validation-summary="ModelOnly" class="alert alert-danger mb-4" role="alert"></div>

                        <div class="mb-3">
                            <label asp-for="MovieName" class="sf-label"></label>
                            <input asp-for="MovieName" class="sf-input" />
                            <span asp-validation-for="MovieName" class="sf-validation"></span>
                        </div>
                        <div class="mb-3">
                            <label asp-for="Genre" class="sf-label"></label>
                            <input asp-for="Genre" class="sf-input" />
                            <span asp-validation-for="Genre" class="sf-validation"></span>
                        </div>
                        <div class="mb-3">
                            <label asp-for="MpaRating" class="sf-label"></label>
                            <select asp-for="MpaRating" class="sf-select">
                                <option value="G">G</option>
                                <option value="PG">PG</option>
                                <option value="PG-13">PG-13</option>
                                <option value="R">R</option>
                                <option value="NC-17">NC-17</option>
                            </select>
                            <span asp-validation-for="MpaRating" class="sf-validation"></span>
                        </div>
                        <div class="mb-4">
                            <label asp-for="RunTime" class="sf-label"></label>
                            <input asp-for="RunTime" class="sf-input" type="number" min="1" />
                            <span asp-validation-for="RunTime" class="sf-validation"></span>
                        </div>

                        <div class="d-flex gap-3">
                            <button type="submit" class="btn sf-btn-primary flex-grow-1">
                                <i class="bi bi-save me-2"></i>Save Changes
                            </button>
                            <a asp-controller="Movies" asp-action="MovieDetail" asp-route-id="@Model.MovieId"
                               class="btn sf-btn-outline">Cancel</a>
                        </div>
                    </form>

                    <hr class="sf-divider mt-4" />

                    <form asp-controller="Movies" asp-action="MovieDelete" method="post"
                          onsubmit="return confirm('Delete this movie permanently?');">
                        @Html.AntiForgeryToken()
                        <input name="id" type="hidden" value="@Model.MovieId" />
                        <button type="submit" class="btn sf-btn-danger w-100">
                            <i class="bi bi-trash me-2"></i>Delete Movie
                        </button>
                    </form>
                </div>
            </div>
        </div>
    </div>
</section>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
