@*
 * File: /ScrumFlix/Views/Movies/MovieCatalog.cshtml
 * Description: Movie browsing page with search bar, genre filter chips, and responsive poster grid.
*@
@model MovieCatalogViewModel
@{
    ViewData["Title"] = "Movies";
}

<div class="sf-page-header">
    <div class="container-xl">
        <h1 class="sf-page-title"><i class="bi bi-film me-3"></i>Movies</h1>
        <p class="sf-page-subtitle">Browse our full catalog of currently showing films.</p>
    </div>
</div>

<section class="sf-section" aria-label="Movie catalog">
    <div class="container-xl">

        <!-- Search + Filter Bar -->
        <form method="get" asp-controller="Movies" asp-action="MovieCatalog"
              class="sf-filter-bar" role="search" aria-label="Filter movies">
            <div class="sf-search-wrap">
                <i class="bi bi-search sf-search-icon" aria-hidden="true"></i>
                <input type="text" name="search" value="@Model.SearchTerm"
                       class="sf-search-input" placeholder="Search movies…"
                       aria-label="Search movies by title" />
            </div>
            <button type="submit" class="btn sf-btn-primary">Search</button>
            @if (!string.IsNullOrEmpty(Model.SearchTerm) || !string.IsNullOrEmpty(Model.SelectedGenre))
            {
                <a asp-controller="Movies" asp-action="MovieCatalog" class="btn sf-btn-outline">
                    <i class="bi bi-x-circle me-1"></i>Clear
                </a>
            }
            <input type="hidden" name="genre" value="@Model.SelectedGenre" />
        </form>

        <!-- Genre Filter Pills -->
        @if (Model.Genres.Any())
        {
            <div class="sf-genre-filter mb-5" role="navigation" aria-label="Filter by genre">
                <a asp-controller="Movies" asp-action="MovieCatalog"
                   asp-route-search="@Model.SearchTerm"
                   class="sf-genre-chip @(string.IsNullOrEmpty(Model.SelectedGenre) ? "active" : "")">
                    All
                </a>
                @foreach (var genre in Model.Genres)
                {
                    <a asp-controller="Movies" asp-action="MovieCatalog"
                       asp-route-genre="@genre"
                       asp-route-search="@Model.SearchTerm"
                       class="sf-genre-chip @(Model.SelectedGenre == genre ? "active" : "")">
                        @genre
                    </a>
                }
            </div>
        }

        <!-- Results Count -->
        <p class="sf-results-count mb-4" aria-live="polite">
            @Model.Movies.Count movie@(Model.Movies.Count == 1 ? "" : "s") found
            @if (!string.IsNullOrEmpty(Model.SearchTerm)) { <span>for "<strong>@Model.SearchTerm</strong>"</span> }
            @if (!string.IsNullOrEmpty(Model.SelectedGenre)) { <span>in <strong>@Model.SelectedGenre</strong></span> }
        </p>

        <!-- Movie Grid -->
        @if (Model.Movies.Any())
        {
            <div class="row g-4">
                @foreach (var movie in Model.Movies)
                {
                    <div class="col-6 col-md-4 col-lg-3 col-xl-2">
                        <article class="sf-movie-card h-100" aria-label="@movie.MovieName">
                            <div class="sf-movie-poster">
                                <div class="sf-poster-placeholder">
                                    <i class="bi bi-film"></i>
                                </div>
                                <div class="sf-poster-overlay">
                                    <a asp-controller="Movies" asp-action="MovieDetail" asp-route-id="@movie.MovieId"
                                       class="btn sf-btn-primary btn-sm w-100 mb-2">
                                        Details
                                    </a>
                                </div>
                                <span class="sf-rating-badge">@movie.MpaRating</span>
                            </div>
                            <div class="sf-movie-card-body">
                                <h2 class="sf-movie-title">@movie.MovieName</h2>
                                <div class="sf-movie-meta">
                                    <span class="sf-genre-pill">@movie.Genre</span>
                                    <span class="sf-runtime">@movie.FormattedRunTime</span>
                                </div>
                            </div>
                        </article>
                    </div>
                }
            </div>
        }
        else
        {
            <div class="sf-empty-state text-center py-5">
                <i class="bi bi-film sf-empty-icon"></i>
                <h3 class="mt-3">No movies found</h3>
                <p class="text-muted">Try adjusting your search or filter.</p>
                <a asp-controller="Movies" asp-action="MovieCatalog" class="btn sf-btn-primary mt-2">
                    View All Movies
                </a>
            </div>
        }

    </div>
</section>
