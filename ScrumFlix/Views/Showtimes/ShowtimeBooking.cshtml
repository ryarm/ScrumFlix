@*
 * File: /ScrumFlix/Views/Showtimes/ShowtimeBooking.cshtml
 * Description: Showtime booking page with theater seat layout visualization, price tier selection,
 *              quantity control, and required email/confirm-email fields with full client-side validation.
*@
@model ShowtimeBookingViewModel
@{
	ViewData["Title"] = $"Book — {Model.Show.Movie?.MovieName}";
	var show = Model.Show;
	var capacity = show.TheaterRoom?.SeatingCapacity ?? 80;
	var sold = show.TicketsSold;
	var available = show.AvailableSeats;
}

<div class="container-xl pt-4">
	<a asp-controller="Movies" asp-action="MovieDetail" asp-route-id="@show.MovieId" class="sf-back-link">
		<i class="bi bi-arrow-left me-1"></i>Back to @show.Movie?.MovieName
	</a>
</div>

<div class="sf-page-header">
	<div class="container-xl">
		<h1 class="sf-page-title">@show.Movie?.MovieName</h1>
		<div class="d-flex flex-wrap gap-3 mt-2 sf-page-subtitle">
			<span><i class="bi bi-calendar3 me-1"></i>@show.StartDateTime.ToString("dddd, MMMM d")</span>
			<span><i class="bi bi-clock me-1"></i>@show.StartDateTime.ToString("h:mm tt") – @show.EndDateTime.ToString("h:mm tt")</span>
			<span><i class="bi bi-geo-alt me-1"></i>@show.Location?.LocationName</span>
			<span><i class="bi bi-display me-1"></i>@show.TheaterRoom?.RoomName</span>
		</div>
	</div>
</div>

<section class="sf-section">
	<div class="container-xl">
		<div class="row g-5">

			<!-- ── Seat Visualization ───────────────────────────────────────── -->
			<div class="col-lg-7">
				<h2 class="sf-section-title mb-4">
					<span class="sf-gold-bar"></span>Theater Layout
				</h2>

				<div class="sf-screen-label" aria-hidden="true"><span>SCREEN</span></div>
				<div class="sf-screen-curve" aria-hidden="true"></div>

				@{
					int cols = show.TheaterRoom?.RoomName?.Contains("IMAX") == true ? 16 : 12;
					int rows = (int)Math.Ceiling((double)capacity / cols);
					int seatN = 0;
				}

				<div class="sf-seat-grid" role="img"
					 aria-label="Seating layout. @available seats available out of @capacity.">
					@for (int r = 0; r < rows; r++)
					{
						<div class="sf-seat-row">
							@for (int c = 0; c < cols && seatN < capacity; c++, seatN++)
							{
								var isSold = seatN < sold;
								<div class="sf-seat @(isSold ? "sf-seat-sold" : "sf-seat-open")"
									 aria-label="@(isSold ? "Seat taken" : "Seat available")"
									 title="@(isSold ? "Taken" : "Available")"></div>
							}
						</div>
					}
				</div>

				<div class="sf-seat-legend mt-3">
					<span class="sf-legend-item">
						<span class="sf-seat sf-seat-open sf-legend-swatch"></span>Available
					</span>
					<span class="sf-legend-item">
						<span class="sf-seat sf-seat-sold sf-legend-swatch"></span>Taken
					</span>
				</div>

				<p class="mt-3 sf-seats-summary">
					<strong class="sf-gold">@available</strong> of @capacity seats available
				</p>
			</div>

			<!-- ── Booking Form ────────────────────────────────────────────── -->
			<div class="col-lg-5">
				<h2 class="sf-section-title mb-4">
					<span class="sf-gold-bar"></span>Select Tickets
				</h2>

				<form asp-controller="Showtimes" asp-action="AddTicketToCart" method="post"
					  class="sf-form-card" novalidate>
					@Html.AntiForgeryToken()
					<input type="hidden" name="Show.ShowId" value="@show.ShowId" />

					<div asp-validation-summary="ModelOnly" class="alert alert-danger mb-4" role="alert"></div>

					<!-- ── Price Tier ─────────────────────────────────────── -->
					<div class="mb-4">
						<label class="sf-label">Ticket Type</label>
						@{
							var isMatineeAllowed = show.StartDateTime.TimeOfDay < TimeSpan.FromHours(14);
						}

						@foreach (var tier in Model.PriceTiers)
						{
							@* var isMatineeTier =
								string.Equals(tier.CategoryName, "Matinee Special", StringComparison.OrdinalIgnoreCase)
								|| string.Equals(tier.FormatType, "Matinee Special", StringComparison.OrdinalIgnoreCase); *@

							var isMatineeTier = string.Equals(tier.CategoryName, "Matinee Special", StringComparison.OrdinalIgnoreCase);

							if (!isMatineeAllowed && isMatineeTier)
							{
								continue;
							}

							<label class="sf-tier-option @(tier.FormatType == "IMAX" ? "sf-tier-imax" : "")"
								   aria-label="@tier.CategoryName — @tier.Price.ToString("C")">
								<input type="radio" name="SelectedPriceTierId" value="@tier.PriceTierId"
								@(tier.PriceTierId == Model.PriceTiers.First().PriceTierId ? "checked" : "") />
								<div class="sf-tier-info">
									<span class="sf-tier-name">@tier.CategoryName</span>
									<span class="sf-tier-desc">@tier.Description</span>
								</div>
								<span class="sf-tier-price">@tier.Price.ToString("C")</span>
							</label>
						}
						<span asp-validation-for="SelectedPriceTierId" class="sf-validation"></span>
					</div>

					<!-- ── Quantity ───────────────────────────────────────── -->
					<div class="mb-4">
						<label asp-for="Quantity" class="sf-label"></label>
						<div class="sf-qty-control">
							<button type="button" class="sf-qty-btn"
									onclick="adjustQty(-1)" aria-label="Decrease quantity">
								−
							</button>
							<input asp-for="Quantity" id="qtyInput" class="sf-qty-input"
								   type="number" min="1" max="20" readonly
								   aria-label="Ticket quantity" />
							<button type="button" class="sf-qty-btn"
									onclick="adjustQty(1)" aria-label="Increase quantity">
								+
							</button>
						</div>
						<span asp-validation-for="Quantity" class="sf-validation"></span>
					</div>

					<!-- ── Email Address ──────────────────────────────────── -->
					<div class="mb-3">
						<label asp-for="GuestEmail" class="sf-label"></label>
						<input asp-for="GuestEmail" class="sf-input" type="email"
							   autocomplete="email"
							   placeholder="your@email.com"
							   aria-describedby="emailHelp" />
						<small id="emailHelp" class="sf-field-hint">
							<i class="bi bi-info-circle me-1"></i>
							Your confirmation will be sent to this address.
						</small>
						<span asp-validation-for="GuestEmail" class="sf-validation"></span>
					</div>

					<!-- ── Confirm Email ───────────────────────────────────── -->
					<div class="mb-4">
						<label asp-for="ConfirmEmail" class="sf-label"></label>
						<input asp-for="ConfirmEmail" class="sf-input" type="email"
							   autocomplete="off"
							   placeholder="Repeat your email address" />
						<span asp-validation-for="ConfirmEmail" class="sf-validation"></span>
					</div>

					<button type="submit" class="btn sf-btn-primary w-100 btn-lg"
						@(available == 0 ? "disabled" : "")>
						<i class="bi bi-cart-plus me-2"></i>
						@(available == 0 ? "Sold Out" : "Add to Cart")
					</button>

					<button type="submit" name="postAction" value="addAndGoToConcessions"
							id="addConcessionsBtn"
							data-authenticated="@(User?.Identity?.IsAuthenticated == true ? "true" : "false")"
							class="btn sf-btn-outline w-100 mt-2">
						<i class="bi bi-cup-straw me-2"></i>Add Concessions Too
					</button>
				</form>
			</div>

		</div>
	</div>
</section>

@section Scripts {
	<partial name="_ValidationScriptsPartial" />
	<script>
		// Quantity stepper
		function adjustQty(delta) {
			const input = document.getElementById('qtyInput');
			input.value = Math.min(20, Math.max(1, parseInt(input.value || 1) + delta));
		}

		// Live confirm-email match indicator
		const emailInput   = document.getElementById('GuestEmail');
		const confirmInput = document.getElementById('ConfirmEmail');

		function checkMatch() {
			if (!confirmInput.value) return;
			const match = emailInput.value === confirmInput.value;
			confirmInput.classList.toggle('sf-input-valid',   match);
			confirmInput.classList.toggle('sf-input-invalid', !match);
		}

		emailInput?.addEventListener('input', checkMatch);
		confirmInput?.addEventListener('input', checkMatch);

		// New: intercept "Add Concessions Too" submit to ensure tickets will be added only
		// when GuestEmail is present (or user is authenticated).
		document.getElementById('addConcessionsBtn')?.addEventListener('click', function (e) {
			const isAuthenticated = document.getElementById('addConcessionsBtn')?.dataset?.authenticated === 'true';
			const qty = parseInt(document.getElementById('qtyInput').value || '0', 10);
			const email = (emailInput?.value || '').trim();

			// If no tickets selected, just let the form submit (it will add nothing).
			if (qty <= 0) return;

			// If authenticated or an email was supplied, allow form submit so tickets get added then
			// the server will redirect to ConcessionsCatalog when it sees postAction == addAndGoToConcessions.
			if (isAuthenticated === "true" || email.length > 0) {
				return;
			}

			// No email and not authenticated: confirm whether user wants to proceed without adding tickets.
			e.preventDefault();
			if (confirm("No email provided. Continue to concessions without adding tickets?")) {
				// redirect directly to concessions catalog
				window.location.href = '@Url.Action("ConcessionsCatalog", "Concessions")';
			}
			// else do nothing (user can enter an email and click again)
		});
	</script>
}
