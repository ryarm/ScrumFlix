@*
 * File: /ScrumFlix/Views/Cart/OrderConfirmation.cshtml
 * Description: Order confirmation page shown after successful checkout.
*@
@{
    ViewData["Title"] = "Order Confirmed";
}

<section class="sf-section">
    <div class="container-xl">
        <div class="row justify-content-center">
            <div class="col-lg-6 text-center">
                <div class="sf-confirm-icon" aria-hidden="true">
                    <i class="bi bi-check-circle-fill"></i>
                </div>
                <h1 class="sf-confirm-title mt-4">Order Confirmed!</h1>
                <p class="sf-confirm-sub">
                    Thank you for choosing ScrumFlix Theatres. Enjoy the show!
                </p>

                @if (ViewBag.OrderTotal != null)
                {
                    <div class="sf-confirm-total mt-4">
                        <span class="sf-confirm-label">Order Total</span>
                        <span class="sf-confirm-amount">@ViewBag.OrderTotal</span>
                    </div>
                }

                <p class="text-muted mt-3">
                    A confirmation has been noted for your records.
                </p>

                <div class="d-flex justify-content-center gap-3 mt-5">
                    <a asp-controller="Home" asp-action="HomeDashboard" class="btn sf-btn-primary btn-lg">
                        <i class="bi bi-house-door me-2"></i>Back to Home
                    </a>
                    <a asp-controller="Movies" asp-action="MovieCatalog" class="btn sf-btn-outline btn-lg">
                        <i class="bi bi-film me-2"></i>Browse Movies
                    </a>
                </div>
            </div>
        </div>
    </div>
</section>
