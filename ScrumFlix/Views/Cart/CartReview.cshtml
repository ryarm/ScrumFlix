@*
 * File: /ScrumFlix/Views/Cart/CartReview.cshtml
 * Description: Shopping cart review page showing all items, quantity controls, tax calculation, and checkout CTA.
*@
@model CartViewModel
@{
	ViewData["Title"] = "Your Cart";
}

<div class="sf-page-header">
	<div class="container-xl">
		<h1 class="sf-page-title"><i class="bi bi-cart3 me-3"></i>Your Cart</h1>
	</div>
</div>

<section class="sf-section">
	<div class="container-xl">

		@if (Model.IsEmpty)
		{
			<div class="sf-empty-state text-center py-5">
				<i class="bi bi-cart-x sf-empty-icon"></i>
				<h2 class="mt-3">Your cart is empty</h2>
				<p class="text-muted">Add movies or concessions to get started.</p>
				<div class="d-flex justify-content-center gap-3 mt-4">
					<a asp-controller="Movies" asp-action="MovieCatalog" class="btn sf-btn-primary">
						<i class="bi bi-film me-2"></i>Browse Movies
					</a>
					<a asp-controller="Concessions" asp-action="ConcessionsCatalog" class="btn sf-btn-outline">
						<i class="bi bi-cup-straw me-2"></i>Order Concessions
					</a>
				</div>
			</div>
		}
		else
		{
			<div class="row g-5 align-items-start">

				<!-- ── Cart Items ─────────────────────────────────────────────── -->
				<div class="col-lg-8">
					<h2 class="sf-section-title mb-4">
						<span class="sf-gold-bar"></span>Cart Items
					</h2>

					@foreach (var item in Model.Items)
					{
						<div class="sf-cart-item" role="listitem">
							<div class="sf-cart-item-icon" aria-hidden="true">
								@if (item.ItemType == CartItemType.Ticket)
								{
									<i class="bi bi-ticket-perforated"></i>
								}
								else
								{
									<i class="bi bi-cup-straw"></i>
								}
							</div>

							<div class="sf-cart-item-details flex-grow-1">
								<div class="sf-cart-item-name">@item.DisplayName</div>
								@if (item.ItemType == CartItemType.Ticket && item.ShowTime.HasValue)
								{
									<div class="sf-cart-item-meta">
										<i class="bi bi-clock me-1"></i>@item.ShowTime.Value.ToString("ddd MMM d · h:mm tt")
										@if (!string.IsNullOrEmpty(item.LocationName))
										{
											<span class="ms-2"><i class="bi bi-geo-alt me-1"></i>@item.LocationName</span>
										}
									</div>
								}
								<div class="sf-cart-item-price-unit">@item.UnitPrice.ToString("C") each</div>
							</div>

							<div class="sf-cart-item-controls">
								<!-- Quantity -->
								<form asp-controller="Cart" asp-action="UpdateQuantity" method="post"
									  class="d-flex align-items-center gap-1">
									@Html.AntiForgeryToken()
									<input type="hidden" name="cartItemId" value="@item.CartItemId" />
									<div class="sf-qty-control sf-qty-sm">
										<button type="button" class="sf-qty-btn"
												onclick="submitQty(this, -1)"
												aria-label="Decrease quantity">
											−
										</button>
										<input type="number" name="quantity" value="@item.Quantity"
											   min="0" max="20" class="sf-qty-input"
											   onchange="this.form.submit()" aria-label="Quantity" />
										<button type="button" class="sf-qty-btn"
												onclick="submitQty(this, 1)"
												aria-label="Increase quantity">
											+
										</button>
									</div>
								</form>

								<!-- Line Total -->
								<span class="sf-cart-line-total">@item.LineTotal.ToString("C")</span>

								<!-- Remove -->
								<form asp-controller="Cart" asp-action="RemoveItem" method="post">
									@Html.AntiForgeryToken()
									<input type="hidden" name="cartItemId" value="@item.CartItemId" />
									<button type="submit" class="sf-cart-remove" aria-label="Remove @item.DisplayName from cart">
										<i class="bi bi-x-circle"></i>
									</button>
								</form>
							</div>
						</div>
					}

					<!-- Clear Cart -->
					<div class="mt-4 text-end">
						<form asp-controller="Cart" asp-action="ClearCart" method="post"
							  onsubmit="return confirm('Clear your entire cart?');">
							@Html.AntiForgeryToken()
							<button type="submit" class="btn sf-btn-ghost btn-sm">
								<i class="bi bi-trash me-1"></i>Clear Cart
							</button>
						</form>
					</div>
				</div>

				<!-- ── Order Summary ───────────────────────────────────────────── -->
				<div class="col-lg-4">
					<div class="sf-order-summary" aria-label="Order summary">
						<h2 class="sf-order-summary-title">Order Summary</h2>

						<div class="sf-summary-row">
							<span>Subtotal</span>
							<span>@Model.Subtotal.ToString("C")</span>
						</div>
						<div class="sf-summary-row">
							<span>Texas Sales Tax (@(Model.TaxRate.ToString("P2")))</span>
							<span>@Model.Tax.ToString("C")</span>
						</div>
						<div class="sf-summary-divider"></div>
						<div class="sf-summary-row sf-summary-total">
							<span>Total</span>
							<span>@Model.Total.ToString("C")</span>
						</div>

						<form asp-controller="Cart" asp-action="Checkout" method="post" class="mt-4">
							@Html.AntiForgeryToken()
							<button type="submit" class="btn sf-btn-primary w-100 btn-lg">
								<i class="bi bi-bag-check me-2"></i>Complete Order
							</button>
						</form>

						<div class="sf-summary-links mt-3">
							<a asp-controller="Movies" asp-action="MovieCatalog">
								<i class="bi bi-arrow-left me-1"></i>Add More Tickets
							</a>
							<span class="sf-summary-divider-inline">·</span>
							<a asp-controller="Concessions" asp-action="ConcessionsCatalog">
								Add Concessions
							</a>
						</div>

						<div class="sf-secure-badge mt-4" aria-label="Secure checkout">
							<i class="bi bi-shield-check me-2"></i>Secure Checkout
						</div>
					</div>
				</div>

			</div>
		}

	</div>
</section>

@section Scripts {
	<script>
		function submitQty(btn, delta) {
			const form  = btn.closest('form');
			const input = form.querySelector('input[name="quantity"]');
			input.value = Math.max(0, Math.min(20, parseInt(input.value || 1) + delta));
			form.submit();
		}
	</script>
}
