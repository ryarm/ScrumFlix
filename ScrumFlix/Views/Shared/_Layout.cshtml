@*
 * File: /ScrumFlix/Views/Shared/_Layout.cshtml
 * Description: Main site layout with cinematic dark theme, sticky nav with cart badge, and responsive footer.
*@
<!DOCTYPE html>
<html lang="en">
<head>
	<meta charset="utf-8" />
	<meta name="viewport" content="width=device-width, initial-scale=1.0" />
	<meta name="author" content="James Porter">
	<meta name="description" content="This page includes content assisted by AI tools.">
	<title>@(ViewData["Title"] != null ? $"{ViewData["Title"]} — ScrumFlix" : "ScrumFlix Theatres")</title>
	<link rel="preconnect" href="https://fonts.googleapis.com" />
	<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
	<link href="https://fonts.googleapis.com/css2?family=Bebas+Neue&family=Outfit:wght@300;400;500;600;700&display=swap" rel="stylesheet" />
	<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.8/dist/css/bootstrap.min.css" />
	<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" />
	<link rel="stylesheet" href="~/css/scrumflix.css" asp-append-version="true" />
</head>
<body>

	<!-- ══ NAVBAR ═══════════════════════════════════════════════════════════════ -->
	<nav class="navbar navbar-expand-lg sf-navbar sticky-top" aria-label="Main navigation">
		<div class="container-xl">

			<a class="navbar-brand sf-brand" asp-controller="Home" asp-action="HomeDashboard">
				<img src="~/images/logo.png" alt="ScrumFlix Theatres" height="42" class="me-2" />
				<span class="sf-brand-text">ScrumFlix</span>
			</a>

			<button class="navbar-toggler" type="button" data-bs-toggle="collapse"
					data-bs-target="#sfNav" aria-controls="sfNav"
					aria-expanded="false" aria-label="Toggle navigation">
				<i class="bi bi-list sf-toggler-icon"></i>
			</button>

			<div class="collapse navbar-collapse" id="sfNav">
				<ul class="navbar-nav me-auto mb-2 mb-lg-0 gap-1">
					<li class="nav-item">
						<a class="nav-link sf-nav-link" asp-controller="Home" asp-action="HomeDashboard">
							<i class="bi bi-house-door me-1"></i>Home
						</a>
					</li>
					<li class="nav-item">
						<a class="nav-link sf-nav-link" asp-controller="Movies" asp-action="MovieCatalog">
							<i class="bi bi-film me-1"></i>Movies
						</a>
					</li>
					<li class="nav-item">
						<a class="nav-link sf-nav-link" asp-controller="Concessions" asp-action="ConcessionsCatalog">
							<i class="bi bi-cup-straw me-1"></i>Concessions
						</a>
					</li>
				</ul>

				@{
					var cartCount = ViewBag.CartCount as int? ?? 0;
				}
				<a class="btn sf-btn-cart position-relative" asp-controller="Cart" asp-action="CartReview"
					   aria-label="Shopping cart">
					<i class="bi bi-cart3 me-1"></i>Cart

					<span id="cart-count-badge"
						  data-cart-count="@cartCount"
						  class="position-absolute top-0 start-100 translate-middle badge sf-cart-badge @(cartCount == 0 ? "d-none" : "")"
						  aria-live="polite" aria-atomic="true">
						@cartCount <span class="visually-hidden">items in cart</span>
					</span>
				</a>
			</div>

		</div>
	</nav>

	<!-- ══ FLASH MESSAGE ════════════════════════════════════════════════════════ -->
	@if (TempData["SuccessMessage"] != null)
	{
		<div class="sf-flash-banner" role="alert" aria-live="polite">
			<div class="container-xl d-flex align-items-center gap-2">
				<i class="bi bi-check-circle-fill"></i>
				<span>@TempData["SuccessMessage"]</span>
			</div>
		</div>
	}

	<!-- ══ MAIN CONTENT ══════════════════════════════════════════════════════════ -->
	<main id="main-content" tabindex="-1">
		@RenderBody()
	</main>

	<!-- ══ FOOTER ═══════════════════════════════════════════════════════════════ -->
	<footer class="sf-footer mt-auto">
		<div class="container-xl">
			<div class="row gy-4 align-items-start">
				<div class="col-lg-4">
					<div class="sf-footer-brand mb-2">ScrumFlix</div>
					<p class="sf-footer-tagline">The best seat in the house — 10 DFW locations.</p>
				</div>
				<div class="col-6 col-lg-2 offset-lg-2">
					<h6 class="sf-footer-heading">Explore</h6>
					<ul class="list-unstyled sf-footer-links">
						<li><a asp-controller="Movies" asp-action="MovieCatalog">Movies</a></li>
						<li><a asp-controller="Concessions" asp-action="ConcessionsCatalog">Concessions</a></li>
						<li><a asp-controller="Cart" asp-action="CartReview">Cart</a></li>
					</ul>
				</div>
				<div class="col-6 col-lg-2">
					<h6 class="sf-footer-heading">Locations</h6>
					<ul class="list-unstyled sf-footer-links">
						<li>Dallas Central</li>
						<li>Dallas North</li>
						<li>Plano Legacy</li>
						<li>Frisco Star</li>
					</ul>
				</div>
				<div class="col-lg-2">
					<h6 class="sf-footer-heading">Connect</h6>
					<div class="sf-social-icons d-flex gap-3 mt-2">
						<a href="#" aria-label="Twitter/X"><i class="bi bi-twitter-x"></i></a>
						<a href="#" aria-label="Instagram"><i class="bi bi-instagram"></i></a>
						<a href="#" aria-label="Facebook"><i class="bi bi-facebook"></i></a>
					</div>
				</div>
			</div>
			<hr class="sf-footer-divider" />
			<p class="sf-footer-copy text-center mb-0">
				&copy; @DateTime.Now.Year ScrumFlix Theatres. All rights reserved.
			</p>
		</div>
	</footer>

	<script>
			/**
			 * Fetches the authoritative cart count from the server and updates the
			 * navbar badge: shows/hides it, updates the visible number, and keeps
			 * the visually-hidden accessibility text intact.
			 */
			function refreshCartBadge() {
				fetch('/Cart/GetCartCount')
					.then(function (res) { return res.json(); })
					.then(function (data) {
						var count = Number(data.count) || 0;
						var badge = document.getElementById('cart-count-badge');
						if (!badge) return;

						// Update the data attribute used for CSS/JS consumers
						badge.dataset.cartCount = count;

						// Rebuild inner content: visible number + hidden accessible text
						badge.innerHTML = count + '<span class="visually-hidden"> items in cart</span>';

						// Show or hide the badge
						if (count > 0) {
							badge.classList.remove('d-none');
						} else {
							badge.classList.add('d-none');
						}

						// Keep aria-label current for screen readers
						badge.setAttribute('aria-label', count + ' items in cart');
					})
					.catch(function (err) {
						console.warn('Cart badge refresh failed:', err);
					});
			}

			// Sync badge on every page load in case session changed elsewhere
			refreshCartBadge();
	</script>
	<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.8/dist/js/bootstrap.bundle.min.js"></script>
	<script src="~/js/scrumflix.js" asp-append-version="true"></script>
	@await RenderSectionAsync("Scripts", required: false)
</body>
</html>
