<Project Sdk="Microsoft.NET.Sdk.Web">

	<PropertyGroup>
		<TargetFramework>net10.0</TargetFramework>
		<Nullable>enable</Nullable>
		<ImplicitUsings>enable</ImplicitUsings>
		<RootNamespace>ScrumFlix</RootNamespace>
		<UserSecretsId>scrumflix-cinema-secrets</UserSecretsId>
	</PropertyGroup>

	<ItemGroup>
		<Compile Remove="Controllers\ShowtimesController - Copy.cs" />
		<Compile Remove="ViewModels\ShowtimeBookingViewModel - Copy.cs" />
	</ItemGroup>

	<ItemGroup>
		<Content Remove="Views\Movies\MovieCatalog - Copy.cshtml" />
		<Content Remove="Views\Showtimes\ShowtimeBooking - Copy.cshtml" />
		<Content Remove="wwwroot\css\scrumflix - Copy.css" />
		<Content Remove="wwwroot\css\scrumflix_old.css" />
	</ItemGroup>

	<ItemGroup>
	  <None Remove="Models.zip" />
	</ItemGroup>

	<ItemGroup>
		<PackageReference Include="Microsoft.AspNetCore.Mvc.NewtonsoftJson" Version="10.0.5" />
		<PackageReference Include="Microsoft.EntityFrameworkCore" Version="9.0.4" />
		<PackageReference Include="Microsoft.EntityFrameworkCore.Design" Version="9.0.4">
			<PrivateAssets>all</PrivateAssets>
			<IncludeAssets>runtime; build; native; contentfiles; analyzers; buildtransitive</IncludeAssets>
		</PackageReference>
		<PackageReference Include="Pomelo.EntityFrameworkCore.MySql" Version="9.0.0" />
		<PackageReference Include="Newtonsoft.Json" Version="13.0.4" />
	</ItemGroup>

</Project>
