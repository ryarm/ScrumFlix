-- 12. PROCEDURE: Add new scheduled movie showings

DELIMITER //

CREATE PROCEDURE update_show_schedule (
	movie_id_param INT, 
    location_id_param INT, 
    room_id_param INT, 
    show_date_param DATE, 
    start_datetime_param DATETIME, 
    end_datetime_param DATETIME,
    is_active_param TINYINT
)
BEGIN  

-- Validate that showtimes don't overlap

IF EXISTS (
    SELECT 1
    FROM scheduled_shows
    WHERE room_id = room_id_param
    AND start_datetime_param < end_datetime
    AND end_datetime_param > start_datetime
)
THEN
    SIGNAL SQLSTATE '45000'
    SET MESSAGE_TEXT = 'Showtime conflict detected for this room.';
END IF;
  
-- Insert scheduled showing
INSERT INTO scheduled_shows
	(movie_id, location_id, room_id, show_date, start_datetime, end_datetime, is_active)
VALUES
	(movie_id_param, location_id_param, room_id_param, DATE(start_datetime_param), 
    start_datetime_param, end_datetime_param,is_active_param);

END//

