-- 8. TICKETS
CREATE TABLE tickets (
    ticket_id INT PRIMARY KEY AUTO_INCREMENT,
    show_id INT NOT NULL,
    price_tier_id INT NOT NULL,
    customer_id INT NULL,
    guest_email VARCHAR(255),
    ticket_date DATE NOT NULL,

    CONSTRAINT fk_ticket_show
        FOREIGN KEY (show_id)
        REFERENCES scheduled_shows(show_id)
        ON DELETE CASCADE
        ON UPDATE CASCADE,

    CONSTRAINT fk_ticket_price
        FOREIGN KEY (price_tier_id)
        REFERENCES price_tiers(price_tier_id)
        ON DELETE RESTRICT
        ON UPDATE CASCADE,

    CONSTRAINT fk_ticket_customer
        FOREIGN KEY (customer_id)
        REFERENCES customers(customer_id)
        ON DELETE RESTRICT
        ON UPDATE CASCADE
);

