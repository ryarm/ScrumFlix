-- 24. Create a stored procedure for managers to set prices for concessions items

DROP PROCEDURE IF EXISTS update_concession_price;

DELIMITER //

CREATE PROCEDURE update_concession_price (
    IN item_id_param BINARY(16),
    IN location_id_param INT,
    IN new_price_param DECIMAL(10,2)
)
BEGIN
    -- Validate price
    IF new_price_param < 0 THEN
        SIGNAL SQLSTATE '45000'
        SET MESSAGE_TEXT = 'Price must be non-negative';
    END IF;

    -- End current active pricing record (if one exists)
    UPDATE concessions_pricing
    SET 
        effective_end = CURRENT_TIMESTAMP,
        is_active = FALSE
    WHERE item_id = item_id_param
      AND location_id = location_id_param
      AND is_active = TRUE;

    -- Insert new pricing record
    INSERT INTO concessions_pricing (
        item_id,
        location_id,
        price,
        effective_start,
        is_active
    )
    VALUES (
        item_id_param,
        location_id_param,
        new_price_param,
        CURRENT_TIMESTAMP,
        TRUE
    );

END //

DELIMITER ;

-- 25. Create a stored procedure that produces a ticket sales revenue/count report
DROP PROCEDURE IF EXISTS ticket_sales_report;

DELIMITER //

CREATE PROCEDURE ticket_sales_report (
    IN location_id_param INT,
    IN start_date_range_param DATE,
    IN end_date_range_param DATE
)
BEGIN
    SELECT 
        l.location_id,
        l.location_name,
        ss.show_date,
        m.movie_id,
        m.movie_name,
        COUNT(t.ticket_id) AS tickets_sold,
        COALESCE(SUM(pt.price), 0) AS total_revenue

    FROM scheduled_shows ss
    INNER JOIN locations l 
        ON ss.location_id = l.location_id
    INNER JOIN movies m 
        ON ss.movie_id = m.movie_id
    LEFT JOIN tickets t 
        ON ss.show_id = t.show_id
    LEFT JOIN price_tiers pt 
        ON t.price_tier_id = pt.price_tier_id
    WHERE ss.show_date BETWEEN start_date_range_param AND end_date_range_param
    -- if the location_id_param is left blank the report will return totals for all locations
      AND (ss.location_id = location_id_param OR location_id_param IS NULL)

    GROUP BY 
        l.location_id,
        l.location_name,
        ss.show_date,
        m.movie_id,
        m.movie_name

    ORDER BY 
        ss.show_date,
        m.movie_name;

END //

DELIMITER ;

-- 26. CART TABLE (Persistent, session-scoped)

CREATE TABLE concessions_cart_items (
    session_id BINARY(16) NOT NULL,
    item_id BINARY(16) NOT NULL,
    quantity INT NOT NULL,
    created_at DATETIME DEFAULT CURRENT_TIMESTAMP,
    UNIQUE KEY (session_id, item_id)
);

-- 27. STORED PROCEDURE: Process Concessions Sale

DROP PROCEDURE IF EXISTS process_concessions_sale;

DELIMITER //

CREATE PROCEDURE process_concessions_sale (
    IN location_id_param INT,
    IN employee_id_param INT,
    IN session_id_param BINARY(16)
)
BEGIN
    DECLARE done INT DEFAULT FALSE;

    DECLARE item_id_var BINARY(16);
    DECLARE quantity_var INT;

    DECLARE item_price DECIMAL(10,2);
    DECLARE item_stock INT;

    DECLARE total_amount DECIMAL(10,2) DEFAULT 0;
    DECLARE last_sale_id INT;

    -- Cursor scoped to this session/cart
    DECLARE item_cursor CURSOR FOR
        SELECT item_id, quantity
        FROM concessions_cart_items
        WHERE session_id = session_id_param;

    DECLARE CONTINUE HANDLER FOR NOT FOUND SET done = TRUE;

    -- Rollback on error
    DECLARE EXIT HANDLER FOR SQLEXCEPTION
    BEGIN
        ROLLBACK;
    END;

    START TRANSACTION;

    -- Validate cart is not empty
    IF (
        SELECT COUNT(*)
        FROM concessions_cart_items
        WHERE session_id = session_id_param) = 0 
        THEN
        SIGNAL SQLSTATE '45000'
        SET MESSAGE_TEXT = 'Cart is empty';
    END IF;

    -- Create sale header
    INSERT INTO concessions_sales (
        location_id,
        employee_id,
        sale_datetime,
        total_amount
    )
    VALUES (
        location_id_param,
        employee_id_param,
        CURRENT_TIMESTAMP,
        0
    );

    SET last_sale_id = LAST_INSERT_ID();

    -- Process cart items
    OPEN item_cursor;

    read_loop: LOOP
        FETCH item_cursor INTO item_id_var, quantity_var;

        IF done THEN
            LEAVE read_loop;
        END IF;

        -- Validate quantity
        IF quantity_var IS NULL OR quantity_var <= 0 THEN
            SIGNAL SQLSTATE '45000'
            SET MESSAGE_TEXT = 'Invalid quantity in cart';
        END IF;

        -- Get current price
        SELECT price INTO item_price
        FROM concessions_pricing
        WHERE item_id = item_id_var
          AND location_id = location_id_param
          AND is_active = TRUE
        LIMIT 1;

        IF item_price IS NULL THEN
            SIGNAL SQLSTATE '45000'
            SET MESSAGE_TEXT = 'Item not available for sale';
        END IF;

        -- Lock inventory row
        SELECT item_quantity INTO item_stock
        FROM inventory
        WHERE item_id = item_id_var
          AND location_id = location_id_param
        FOR UPDATE;

        IF item_stock IS NULL THEN
            SIGNAL SQLSTATE '45000'
            SET MESSAGE_TEXT = 'Item not found in inventory';
        END IF;

        IF item_stock < quantity_var THEN
            SIGNAL SQLSTATE '45000'
            SET MESSAGE_TEXT = 'Insufficient stock';
        END IF;

        -- Insert line item
        INSERT INTO concessions_sales_items (
            sale_id,
            item_id,
            quantity,
            unit_price
        )
        VALUES (
            last_sale_id,
            item_id_var,
            quantity_var,
            item_price
        );

        -- Update inventory
        UPDATE inventory
        SET item_quantity = item_quantity - quantity_var
        WHERE item_id = item_id_var
          AND location_id = location_id_param;

        -- Accumulate total
        SET total_amount = total_amount + (quantity_var * item_price);

    END LOOP;

    CLOSE item_cursor;

    -- Update total in header
    UPDATE concessions_sales
    SET total_amount = total_amount
    WHERE sale_id = last_sale_id;

    -- Cleanup cart after successful sale
    DELETE FROM concessions_cart_items
    WHERE session_id = session_id_param;

    COMMIT;

    -- Return result
    SELECT last_sale_id AS sale_id, total_amount;

END //

DELIMITER ;

