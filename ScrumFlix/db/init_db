DROP DATABASE IF EXISTS defaultdb;
CREATE DATABASE IF NOT EXISTS defaultdb;
USE defaultdb;

-- 1. MOVIES
CREATE TABLE movies (
    movie_id INT PRIMARY KEY AUTO_INCREMENT,
    movie_name VARCHAR(150) NOT NULL UNIQUE,
    genre VARCHAR(50) NOT NULL,
    mpa_rating VARCHAR(10) NOT NULL,
    run_time SMALLINT NOT NULL,
    CONSTRAINT chk_run_time CHECK (run_time > 0)
);


-- 2. LOCATIONS
CREATE TABLE locations (
	location_id INT PRIMARY KEY AUTO_INCREMENT,
    location_name VARCHAR(50) NOT NULL UNIQUE,
    location_address VARCHAR(255) NOT NULL UNIQUE,
    is_active BOOLEAN NOT NULL DEFAULT TRUE
);

-- 3. THEATER ROOMS
CREATE TABLE theater_rooms (
    room_id INT PRIMARY KEY AUTO_INCREMENT,
    location_id INT NOT NULL,
    room_name VARCHAR(50) NOT NULL,
    seating_capacity INT NOT NULL CHECK (seating_capacity > 0),
    is_active BOOLEAN NOT NULL DEFAULT TRUE,
    
    CONSTRAINT fk_location
		FOREIGN KEY (location_id)
        REFERENCES locations(location_id)
        ON DELETE RESTRICT
        ON UPDATE CASCADE
);

-- 4. SCHEDULED SHOWS
CREATE TABLE scheduled_shows (
    show_id INT PRIMARY KEY AUTO_INCREMENT,
    movie_id INT NOT NULL,
    room_id INT NOT NULL,
    show_date DATE NOT NULL,
    start_datetime DATETIME NOT NULL,
    end_datetime DATETIME NOT NULL,
    is_active BOOLEAN NOT NULL DEFAULT TRUE,

    CONSTRAINT fk_show_movie
        FOREIGN KEY (movie_id)
        REFERENCES movies(movie_id)
        ON DELETE RESTRICT
        ON UPDATE CASCADE,

    CONSTRAINT fk_show_room
        FOREIGN KEY (room_id)
        REFERENCES theater_rooms(room_id)
        ON DELETE RESTRICT
        ON UPDATE CASCADE,

    CONSTRAINT chk_show_time
        CHECK (end_datetime > start_datetime)
);

-- 5. EMPLOYEES
CREATE TABLE employees (
    employee_id INT PRIMARY KEY AUTO_INCREMENT,
    first_name VARCHAR(50) NOT NULL,
    middle_name VARCHAR(50),
    last_name VARCHAR(50) NOT NULL,
    employee_start_title VARCHAR(50) NOT NULL,
    employee_current_title VARCHAR(50) NOT NULL,
    employee_start_date DATE NOT NULL,
    employee_end_date DATE,
    employee_dob DATE NOT NULL,
    employee_phone VARCHAR(20) NOT NULL,
    employee_email VARCHAR(100) NOT NULL UNIQUE,
    employee_st_address VARCHAR(100),
    employee_city VARCHAR(50) NOT NULL,
    employee_state VARCHAR(40) NOT NULL,
    employee_zipcode VARCHAR(10) NOT NULL
);

-- 6. CUSTOMERS
CREATE TABLE customers (
    customer_id INT PRIMARY KEY AUTO_INCREMENT,
    first_name VARCHAR(50) NOT NULL,
    last_name VARCHAR(50) NOT NULL,
    customer_email VARCHAR(255) NOT NULL UNIQUE,
    customer_phone VARCHAR(20) NOT NULL,
    customer_dob DATE,
    customer_category ENUM('Child','Adult','Senior','Matinee') DEFAULT 'Adult'
);

-- 7. PRICE TIERS
CREATE TABLE price_tiers (
    price_tier_id INT PRIMARY KEY AUTO_INCREMENT,
    category_name VARCHAR(50) NOT NULL,
    format_type VARCHAR(20) DEFAULT '2D',
    price DECIMAL(6,2) NOT NULL CHECK (price >= 0),
    is_active BOOLEAN DEFAULT TRUE,
    description VARCHAR(255)
);

