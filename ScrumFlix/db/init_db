-- 9. TICKETS
CREATE TABLE tickets (
    ticket_id INT PRIMARY KEY AUTO_INCREMENT,
    show_id INT NOT NULL,
    price_tier_id INT NOT NULL,
    customer_id INT NULL,
    guest_email VARCHAR(255),
    ticket_date DATE NOT NULL,

    CONSTRAINT fk_ticket_show
        FOREIGN KEY (show_id)
        REFERENCES scheduled_shows(show_id)
        ON DELETE CASCADE
        ON UPDATE CASCADE,

    CONSTRAINT fk_ticket_price
        FOREIGN KEY (price_tier_id)
        REFERENCES price_tiers(price_tier_id)
        ON DELETE RESTRICT
        ON UPDATE CASCADE,

    CONSTRAINT fk_ticket_customer
        FOREIGN KEY (customer_id)
        REFERENCES customers(customer_id)
        ON DELETE RESTRICT
        ON UPDATE CASCADE
);

-- 10. TRIGGER: Enforce Guest OR Member Rule (INSERT)
DROP TRIGGER IF EXISTS trg_ticket_insert_check;

DELIMITER //

CREATE TRIGGER trg_ticket_insert_check
BEFORE INSERT ON tickets
FOR EACH ROW
BEGIN
    IF NOT (
        (NEW.customer_id IS NOT NULL AND NEW.guest_email IS NULL)
        OR
        (NEW.customer_id IS NULL AND NEW.guest_email IS NOT NULL)
    ) THEN
        SIGNAL SQLSTATE '45000'
        SET MESSAGE_TEXT = 'Ticket must have either customer_id OR guest_email, not both or neither';
    END IF;
END //

DELIMITER ;

-- 11. TRIGGER: Enforce Guest OR Member Rule (UPDATE)
DROP TRIGGER IF EXISTS trg_ticket_update_check;

DELIMITER //

CREATE TRIGGER trg_ticket_update_check
BEFORE UPDATE ON tickets
FOR EACH ROW
BEGIN
    IF NOT (
        (NEW.customer_id IS NOT NULL AND NEW.guest_email IS NULL)
        OR
        (NEW.customer_id IS NULL AND NEW.guest_email IS NOT NULL)
    ) THEN
        SIGNAL SQLSTATE '45000'
        SET MESSAGE_TEXT = 'Ticket must have either customer_id OR guest_email, not both or neither';
    END IF;
END //

DELIMITER ;
