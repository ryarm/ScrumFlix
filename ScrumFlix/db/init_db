-- 20. Add concessions orders received logic
-- Trigger: Set order_received_date when order is marked as received
-- and increase inventory by quantity in purchase order
DROP TRIGGER IF EXISTS trg_set_order_received_date;

DELIMITER //

CREATE TRIGGER trg_set_order_received_date
BEFORE UPDATE ON concessions_orders
FOR EACH ROW
BEGIN
    -- Prevent re-receiving the same order
    IF OLD.order_received = TRUE AND NEW.order_received = TRUE THEN
        SIGNAL SQLSTATE '45000'
        SET MESSAGE_TEXT = 'Order already received';
    END IF;

    -- If order is being marked as received
    IF NEW.order_received = TRUE 
       AND OLD.order_received = FALSE THEN
       
        -- Set received date if not provided
        IF NEW.order_received_date IS NULL THEN
            SET NEW.order_received_date = NOW();
        END IF;

        -- Increment inventory
        UPDATE inventory
        SET item_quantity = item_quantity + NEW.order_quantity
        WHERE item_id = NEW.item_id
          AND location_id = NEW.location_id;

    END IF;

END//

DELIMITER ;

